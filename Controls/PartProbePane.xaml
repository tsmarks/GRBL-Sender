<UserControl x:Class="GRBL_Lathe_Control.Controls.PartProbePane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="700">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Part Probe" Style="{StaticResource SectionTitleStyle}" FontSize="22"/>
                <TextBlock Text="Use a GRBL probe to touch part edges, set work zeros, center holes, and run simple inspection macros. Start with conservative travel/feed values and keep clear of clamps."
                           Style="{StaticResource LabelTextStyle}"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Probe Setup" Style="{StaticResource SectionTitleStyle}" FontSize="18"/>
                    <TextBlock Text="Travel is the maximum probe search distance. Macro move feed is used for non-probing pull-offs, Z lifts, and point-to-point moves."
                               Style="{StaticResource LabelTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>

                    <UniformGrid Columns="3" Margin="0,12,0,0">
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="Travel (mm)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding PartProbeTravelInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="Coarse Feed" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding PartProbeFeedInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Fine Feed" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding PartProbeFineFeedInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="Pull-Off (mm)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding PartProbeRetractInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="Probe Tip Dia" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding PartProbeTipDiameterInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Z Zero Offset" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding PartProbeZOffsetInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="Macro Move Feed" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding PartProbeMoveFeedInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="Min Machine Z" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     ToolTip="Lowest machine Z allowed during downward probe moves. Leave blank to disable the Z travel guard."
                                     Text="{Binding ProbeMinimumMachineZInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Z Clearance" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     ToolTip="Clearance held above Min Machine Z when probe travel is clamped."
                                     Text="{Binding ProbeMinimumClearanceInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </UniformGrid>

                    <CheckBox Content="Set zero after successful touch"
                              Style="{StaticResource InlineCheckBoxStyle}"
                              IsChecked="{Binding PartProbeSetZeroAfterProbe, Mode=TwoWay}"
                              ToolTip="When checked, edge and center probes update the active work coordinate zero."/>
                    <WrapPanel Margin="0,10,0,0">
                        <CheckBox Content="NC Probe ($6=1)"
                                  Style="{StaticResource InlineCheckBoxStyle}"
                                  Margin="0,0,14,0"
                                  ToolTip="Toggle GRBL $6 probe pin invert. Off is NO ($6=0), on is NC ($6=1)."
                                  IsEnabled="{Binding IsConnected}"
                                  IsChecked="{Binding IsProbeNormallyClosed, Mode=TwoWay}"/>
                        <TextBlock Text="{Binding ProbePinModeText}"
                                   Style="{StaticResource BodyTextStyle}"
                                   VerticalAlignment="Center"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Single Touch" Style="{StaticResource SectionTitleStyle}" FontSize="18"/>
                    <TextBlock Text="Edge probes use probe-tip compensation. For example, X- sets the current touched position to probe radius so the part edge becomes X0."
                               Style="{StaticResource LabelTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>

                    <UniformGrid Columns="3" Margin="0,12,0,0">
                        <Button Content="Find X- Edge"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,10"
                                Command="{Binding ProbeXNegativeEdgeCommand}"/>
                        <Button Content="Find X+ Edge"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,10"
                                Command="{Binding ProbeXPositiveEdgeCommand}"/>
                        <Button Content="Z Touch"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,0,0,10"
                                Command="{Binding ProbeZTouchCommand}"/>
                        <Button Content="Find Y- Edge"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Command="{Binding ProbeYNegativeEdgeCommand}"/>
                        <Button Content="Find Y+ Edge"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Command="{Binding ProbeYPositiveEdgeCommand}"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Corner And Center" Style="{StaticResource SectionTitleStyle}" FontSize="18"/>
                    <TextBlock Text="Hole center starts from the approximate center and probes X-/X+/Y-/Y+. The outside cylinder calculator uses the last four side touches, even if work offsets were changed between touches."
                               Style="{StaticResource LabelTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Corner X Direction" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                      ItemsSource="{Binding PartProbeXDirections}"
                                      SelectedItem="{Binding PartProbeCornerXDirection, Mode=TwoWay}"
                                      Margin="0,0,0,10"/>
                            <TextBlock Text="Corner Y Direction" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                      ItemsSource="{Binding PartProbeYDirections}"
                                      SelectedItem="{Binding PartProbeCornerYDirection, Mode=TwoWay}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Button Content="Probe X/Y Corner"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,0,10"
                                    Command="{Binding ProbeXYCornerCommand}"/>
                            <Button Content="Probe Hole Center"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,0,10"
                                    Command="{Binding ProbeHoleCenterCommand}"/>
                            <Button Content="Calc Outside Cylinder"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0"
                                    Command="{Binding CalculateOutsideCylinderCommand}"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#0E1827"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="Edge Measure"
                                       Style="{StaticResource SectionTitleStyle}"
                                       FontSize="16"/>
                            <TextBlock Text="Probe any two X or Y edges manually, then save them as A and B to measure distance and set the center zero."
                                       Style="{StaticResource LabelTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"/>
                            <UniformGrid Columns="4" Margin="0,10,0,0">
                                <Button Content="Set Measure A"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"
                                        Command="{Binding SetPartProbeMeasureACommand}"/>
                                <Button Content="Set Measure B"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"
                                        Command="{Binding SetPartProbeMeasureBCommand}"/>
                                <Button Content="Clear Measure"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,8,8"
                                        Command="{Binding ClearPartProbeMeasurementCommand}"/>
                                <Button Content="Set Center Zero"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,0,0,8"
                                        Command="{Binding SetPartProbeMeasurementCenterZeroCommand}"/>
                            </UniformGrid>
                            <TextBlock Text="{Binding PartProbeMeasurementText}"
                                       Style="{StaticResource BodyTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Straight Edge Macro" Style="{StaticResource SectionTitleStyle}" FontSize="18"/>
                    <TextBlock Text="Touches an X or Y edge, pulls off, optionally raises Z, moves parallel to the edge, then touches again. Result reports drift and angle."
                               Style="{StaticResource LabelTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>

                    <UniformGrid Columns="3" Margin="0,12,0,0">
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="Touch Direction" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                      ItemsSource="{Binding PartProbeEdgeDirections}"
                                      SelectedItem="{Binding StraightEdgeDirection, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="Touches" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding StraightEdgeTouchCountInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Spacing (mm)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding StraightEdgeSpacingInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Perp Pull-Off" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding StraightEdgePullOffInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Z Lift (mm)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding StraightEdgeZLiftInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <Button Content="Run Straight Edge"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0"
                                VerticalAlignment="Bottom"
                                Command="{Binding RunStraightEdgeProbeCommand}"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Surface Grid" Style="{StaticResource SectionTitleStyle}" FontSize="18"/>
                    <TextBlock Text="Probes Z in a serpentine X/Y grid from the current point and reports min, max, range, and average."
                               Style="{StaticResource LabelTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>

                    <UniformGrid Columns="3" Margin="0,12,0,0">
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="X Count" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding SurfaceGridXCountInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="Y Count" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding SurfaceGridYCountInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <Button Content="Run Surface Grid"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,0,10"
                                VerticalAlignment="Bottom"
                                Command="{Binding RunSurfaceGridProbeCommand}"/>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="X Spacing" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding SurfaceGridXSpacingInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Y Spacing" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Text="{Binding SurfaceGridYSpacingInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Background="#0E1827"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14"
                    Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="Last Probe Result" Style="{StaticResource SectionTitleStyle}" FontSize="18"/>
                    <TextBlock Text="{Binding PartProbeResultText}"
                               Style="{StaticResource BodyTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
