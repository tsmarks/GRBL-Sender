<UserControl x:Class="GRBL_Lathe_Control.Controls.ToolDataPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:GRBL_Lathe_Control.Controls"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="700">
    <TabControl Style="{StaticResource PreviewTabControlStyle}"
                BorderThickness="0">
        <TabItem Header="Preview" Style="{StaticResource PreviewTabItemStyle}">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Tool Path Preview" Style="{StaticResource SectionTitleStyle}" FontSize="22"/>
                            <TextBlock Text="Plan view of the loaded program in the lathe's X/Z plane. The live yellow marker tracks the current work position."
                                       Style="{StaticResource LabelTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#0E1827"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12"
                                HorizontalAlignment="Right">
                            <StackPanel>
                                <TextBlock Text="Preview Reference" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding WorkX, StringFormat=X {0:F3} mm}" Style="{StaticResource BodyTextStyle}"/>
                                <TextBlock Text="{Binding WorkZ, StringFormat=Z {0:F3} mm}" Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <controls:ToolPathPreviewControl Grid.Row="2"
                                                     Segments="{Binding ToolPathSegments}"
                                                     CurrentHorizontal="{Binding PreviewHorizontalPosition}"
                                                     CurrentVertical="{Binding PreviewVerticalPosition}"
                                                     HorizontalAxisLabel="{Binding PreviewHorizontalAxisLabel}"
                                                     VerticalAxisLabel="{Binding PreviewVerticalAxisLabel}"/>
                </Grid>
            </Border>
        </TabItem>

        <TabItem Header="Tool Offsets" Style="{StaticResource PreviewTabItemStyle}">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Tool Offsets" Style="{StaticResource SectionTitleStyle}" FontSize="22"/>
                        <TextBlock Text="Add tools manually or let the program load create missing tool rows. T0 is the master tool at X 0 / Z 0. Set stores the tool-tip offset from T0, so it saves the opposite of the displayed work delta while you touch off the new tool. Use swaps from the current tool to the selected tool by applying the delta between their stored offsets."
                                   Style="{StaticResource LabelTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Margin="0"
                                 ToolTip="Enter a tool number to add a new offset row."
                                 Text="{Binding NewToolNumberInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2"
                                Content="Add Tool"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0"
                                ToolTip="Add a new tool offset row without overwriting any existing values."
                                Command="{Binding AddToolCommand}"/>
                        <CheckBox Grid.Column="4"
                                  Content="Locked"
                                  IsChecked="{Binding IsToolOffsetsLocked, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  ToolTip="Hide the Set and Delete buttons to avoid accidental tool table edits."
                                  Foreground="{StaticResource ValueBrush}"
                                  FontFamily="Bahnschrift"
                                  FontSize="14"
                                  FontWeight="SemiBold"/>
                    </Grid>

                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ToolOffsets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0E1827"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Tool" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding ToolNumber, StringFormat=T{0}}"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           FontFamily="Consolas"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="X Tip Offset" Style="{StaticResource LabelTextStyle}"/>
                                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                         Margin="0"
                                                         Text="{Binding XOffsetInput, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="3">
                                                <TextBlock Text="Z Tip Offset" Style="{StaticResource LabelTextStyle}"/>
                                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                         Margin="0"
                                                         Text="{Binding ZOffsetInput, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="5"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Bottom">
                                                <Button Content="Set"
                                                        Width="66"
                                                        Height="40"
                                                        Margin="0,0,8,0"
                                                        ToolTip="Store this tool's tip offset from T0 by inverting the currently displayed work X and Z."
                                                        Command="{Binding SetCommand}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsToolOffsetsLocked, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Content="Use"
                                                        Width="66"
                                                        Height="40"
                                                        Margin="0"
                                                        ToolTip="Shift the active work zero using this tool's stored tip offset from T0."
                                                        Command="{Binding UseCommand}"
                                                        Style="{StaticResource PrimaryButtonStyle}"/>

                                                <Button Content="Delete"
                                                        Width="74"
                                                        Height="40"
                                                        Margin="8,0,0,0"
                                                        ToolTip="Remove this tool from the saved tool-offset list."
                                                        Command="{Binding DeleteCommand}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding DataContext.IsToolOffsetsLocked, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False"/>
                                                                        <Condition Binding="{Binding CanDeleteTool}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </TabItem>

        <TabItem Header="Terminal" Style="{StaticResource PreviewTabItemStyle}">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
                <controls:GrblTerminalPane/>
            </Border>
        </TabItem>

        <TabItem Header="Settings" Style="{StaticResource PreviewTabItemStyle}">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
                <controls:AppSettingsPane/>
            </Border>
        </TabItem>
    </TabControl>
</UserControl>
